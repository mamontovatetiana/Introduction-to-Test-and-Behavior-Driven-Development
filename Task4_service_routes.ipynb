    "@app.route(\"/products/<int:product_id>\", methods=[\"GET\"])\n",
    "def get_products(product_id):\n",
    "    product = Product.find(product_id)\n",
    "    if not product:\n",
    "        abort(status.HTTP_404_NOT_FOUND)\n",
    "    return jsonify(product.serialize()), status.HTTP_200_OK\n"
   ]
